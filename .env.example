# Runtime provider: local or online
RAG_GENERATION_PROVIDER=local

# Online generation settings, used only when RAG_GENERATION_PROVIDER=online
RAG_ONLINE_MODEL_NAME=gpt-5.5
RAG_ONLINE_API_BASE_URL=https://relayai.tech/v1
RAG_ONLINE_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=

# Retrieval models and thresholds
RAG_EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
RAG_RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RAG_MODEL_RERANK_WEIGHT=0.01
RAG_MIN_VECTOR_SCORE=0.40
RAG_FAISS_STORE_DIR=data/faiss_store

# Answer stabilization
RAG_ANSWER_COMPOSER_ENABLED=true
RAG_REPLY_RULES_ENABLED=true
